# ─── Database ────────────────────────────────────────────────────────────────
# Neon serverless PostgreSQL connection string (required for live data)
#
# Neon branch policy — Omterminal uses exactly two Neon branches:
#   production  → set DATABASE_URL in Vercel "Production" environment scope
#   vercel-dev  → set DATABASE_URL in Vercel "Preview" + "Development" scopes
#
# Automatic per-preview Neon branch creation is DISABLED.
# All preview deploys share the vercel-dev branch.
# The app never creates or selects Neon branches at runtime.
# DATABASE_URL_UNPOOLED is not used — the Neon HTTP driver handles pooling.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Database provider selection: "neon" | "supabase" | "mock" (default: mock)
DB_PROVIDER=mock

# Supabase (alternative to Neon)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
DATABASE_KEY=your-database-key

# ─── News Ingestion ───────────────────────────────────────────────────────────
# GNews API key — used by both /api/news and the ingestion pipeline
# Get yours at: https://gnews.io
GNEWS_API_KEY=your-gnews-api-key

# ─── Ingestion Timeout Guards ─────────────────────────────────────────────────
# All values are in milliseconds.  Defaults are conservative and production-safe.
# Increase only if you have reliable infrastructure with predictably fast sources.

# Per-feed RSS fetch timeout (rssFetcher.ts).  Default: 10 s.
# Feeds that exceed this deadline are skipped; other feeds continue unaffected.
RSS_FEED_TIMEOUT_MS=10000

# Per-query GNews fetch timeout (gnewsFetcher.ts).  Default: 15 s.
# Queries that exceed this deadline return no articles; remaining queries continue.
GNEWS_FETCH_TIMEOUT_MS=15000

# Timeout for the full ingestGNews() call inside /api/ingest.  Default: 8 s.
# Must be well under maxDuration=10 s to allow time to send a structured response.
INGEST_ROUTE_TIMEOUT_MS=8000

# Pipeline stage timeouts (pipeline/run/route.ts).
# Each stage runs independently; a timeout in one stage does not abort later stages.
PIPELINE_INGEST_TIMEOUT_MS=30000    # Stage 1: RSS + GNews ingestion
PIPELINE_SIGNALS_TIMEOUT_MS=10000   # Stage 2: signal generation + DB writes
PIPELINE_SNAPSHOT_TIMEOUT_MS=15000  # Stage 3: page snapshot generation
PIPELINE_CACHE_TIMEOUT_MS=5000      # Stage 4: Redis invalidation + route revalidation
PIPELINE_TIMEOUT_MS=55000           # Overall pipeline hard limit (< Vercel maxDuration=60 s)

# ─── Email / Notifications ───────────────────────────────────────────────────
# Resend API key for the waitlist subscribe endpoint and weekly digest
# Get yours at: https://resend.com
RESEND_KEY=re_your-resend-api-key

# Resend audience ID for the waitlist contact list
RESEND_AUDIENCE=your-audience-id

# From address used in digest emails (must be a verified Resend sender)
DIGEST_FROM=OM Terminal <digest@omterminal.com>

# ─── Cache (Upstash Redis) ──────────────────────────────────────────────────
# Upstash Redis REST API endpoint and token (optional but recommended)
# Without these, the app falls back to in-memory + CDN caching only.
# Get yours at: https://upstash.com
UPSTASH_REDIS_REST_URL=https://your-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ─── AI / LLM Providers ────────────────────────────────────────────────────
# At least one LLM provider is needed for trend analysis and insight generation.
# AI_PROVIDER selects the active provider: "groq" | "grok" | "openai" | "ollama" (default: auto-detect)
# Auto-detect priority: Ollama (local) → Groq (production) → Grok → OpenAI
AI_PROVIDER=groq
GROQ_API_KEY=your-groq-api-key
GROK_API_KEY=your-grok-api-key
OPENAI_API_KEY=your-openai-api-key

# ─── Cron / Scheduling ───────────────────────────────────────────────────────
# Secret token to authorize all scheduled pipeline invocations.
# Vercel passes this automatically via the Authorization: Bearer <CRON_SECRET> header.
# Set this to a random string and configure it in Vercel project settings → Environment Variables.
#
# Scheduled routes (configured in vercel.json):
#   /api/pipeline/run     — PRIMARY   — every hour      (data ingestion: RSS + GNews → events → signals)
#   /api/intelligence/run — SECONDARY — every two hours (intelligence analysis: harvester → trends → insights)
#   /api/digest           — WEEKLY    — Friday 09:00 UTC (email digest to subscribers)
#
# Manual trigger (for testing):
#   curl -H "Authorization: Bearer <CRON_SECRET>" https://omterminal.com/api/pipeline/run
#   curl -H "Authorization: Bearer <CRON_SECRET>" https://omterminal.com/api/pipeline/run?dry_run=true
#
# Pipeline concurrency lock TTL — how long a lock is held before expiring automatically.
# Increase if your pipeline stages can legitimately run longer than 5 minutes.
# Default: 300 (5 minutes).  Must be less than the time between scheduled runs.
PIPELINE_LOCK_TTL_SECONDS=300
CRON_SECRET=your-random-secret-string

# ─── Admin Secret ─────────────────────────────────────────────────────────────
# Secret key for admin-only endpoints such as /api/migrate.
# Usage: GET /api/migrate?key=<ADMIN_SECRET>
# Example migration URL: https://www.omterminal.com/api/migrate?key=omterminal_admin_2026
ADMIN_SECRET=omterminal_admin_2026

# ─── App URL (Production only) ─────────────────────────────────────────────────
# Canonical public URL — used by internal fetch calls and the harvester sender.
# Set this in Vercel "Production" environment scope only.
# Prevents internal calls from resolving to a preview deployment URL in production.
NEXT_PUBLIC_APP_URL=https://omterminal.com
